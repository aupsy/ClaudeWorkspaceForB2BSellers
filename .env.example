# CRM Credentials — copy this file to .env and fill in your values
# .env is gitignored and must never be committed
#
# Each seller configures their own .env with their own credentials.
# This ensures CRM data is always fetched as the authenticated seller,
# so org sharing rules and RBAC are respected automatically.

# ── Salesforce ──────────────────────────────────────────────────────────────
# See SALESFORCE-SETUP.md for how to get these values.

SALESFORCE_USERNAME=your.email@company.com
SALESFORCE_PASSWORD=yourpassword
SALESFORCE_SECURITY_TOKEN=yourtoken
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# ── Future CRM Support ───────────────────────────────────────────────────────
# HubSpot (when mcp-server-hubspot is configured in .mcp.json)
# HUBSPOT_ACCESS_TOKEN=your_private_app_token

# Microsoft Dynamics 365 (when mcp-server-dynamics is configured in .mcp.json)
# DYNAMICS_TENANT_ID=your_tenant_id
# DYNAMICS_CLIENT_ID=your_client_id
# DYNAMICS_CLIENT_SECRET=your_client_secret
# DYNAMICS_INSTANCE_URL=https://yourorg.crm.dynamics.com

# ── Seismic (used by /hydrate seismic) ───────────────────────────────────────
# See SALESFORCE-SETUP.md → Seismic section for how to get these values.
# SEISMIC_TENANT=yourcompany.seismic.com
# SEISMIC_TOKEN=your_bearer_token

# ── Productivity Tools (optional — enrich call-prep, deal-health, email-drafter) ──
# Configure one or more. Skills use whichever are available and skip the rest.
# See SALESFORCE-SETUP.md → Productivity Tools section for setup instructions.

# Microsoft 365 / WorkIQ (recommended for M365 environments)
# Enables: recent emails + meeting notes by account, personal email style learning
# WORKIQ_API_KEY=your_workiq_api_key

# Slack
# Enables: search Slack messages and threads mentioning an account
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_TEAM_ID=T0123456789

# Google Workspace (Gmail + Calendar)
# Enables: recent Gmail threads by account, calendar meetings, email style learning
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REFRESH_TOKEN=your_refresh_token
